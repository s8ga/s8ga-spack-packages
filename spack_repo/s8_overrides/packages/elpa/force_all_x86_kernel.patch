From: ELPA force_all_x86_kernel patch
Subject: [PATCH] Force build AVX512 kernels with per-object CFLAGS on non-AVX512 hosts

This patch enables building AVX512 kernels on AVX2 (or lower) hosts by:
  1. Relaxing configure AVX512 compile tests from hard errors to warnings
  2. Defining AVX512_CFLAGS with compiler-specific flags (GCC/Clang/Intel)
  3. Applying per-object CFLAGS to AVX512 kernel .lo targets only

Main library code remains compiled with host-default flags (e.g. AVX2),
while AVX512 kernels get extra -mavx512f flags. ELPA's runtime autotune
will automatically select the optimal kernel for the deployment host.

Intended to be used with Spack variant +force_all_x86_kernel.

NOTE: Generated from ELPA 2021.05.002 source. GNU patch will auto-locate
      the correct positions by context matching across ELPA versions
      (2021.05 ~ 2026.02+) with its default fuzz factor of 2.
--- a/configure.ac
+++ b/configure.ac
@@ -1527,10 +1527,28 @@
   )
   AC_MSG_RESULT([${can_compile_avx512}])
   if test x"$can_compile_avx512" != x"yes"; then
-    AC_MSG_ERROR([Could not compile a test program with AVX512, adjust the C compiler or CFLAGS. Possibly (some of) the flags " $SIMD_FLAGS " solve this issue])
+    AC_MSG_WARN([Could not compile a test program with AVX512, but forcing AVX512 support enabled as requested])
+    can_compile_avx512=yes
   fi
   AC_DEFINE([HAVE_AVX512],[1],[AVX512 is supported on this CPU])
 
+  # Per-object CFLAGS for AVX512 kernel files only
+  # Compiler-specific flags: GCC/Clang use -mavx512f syntax, Intel uses -xCORE-AVX512
+  if test x"$GCC" = x"yes" || test x"$ac_cv_c_compiler_gnu" = x"yes"; then
+    AVX512_CFLAGS="-mavx512f -mavx512cd -mavx512vl -mavx512bw -mavx512dq"
+  else
+    case "$CC" in
+      *icc*|*icx*|*ifort*|*ifx*)
+        AVX512_CFLAGS="-xCORE-AVX512"
+        ;;
+      *)
+        # Fallback: try GCC-style flags
+        AVX512_CFLAGS="-mavx512f -mavx512cd -mavx512vl -mavx512bw -mavx512dq"
+        ;;
+    esac
+  fi
+  AC_SUBST([AVX512_CFLAGS])
+
   if test x"$can_compile_avx512" = x"yes"; then
     AC_MSG_CHECKING([whether we compile for Xeon])
     AC_COMPILE_IFELSE([AC_LANG_SOURCE([
@@ -1583,7 +1601,8 @@
       if test x"$can_compile_avx512_xeon_phi" = x"yes"; then
         AC_DEFINE([HAVE_AVX512_XEON_PHI],[1],[AVX512 for Xeon-PHI is supported on this CPU])
       else
-        AC_MSG_ERROR([Oho! We can neither compile AVX512 intrinsics for Xeon nor Xeon Phi. This should not happen!])
+        AC_MSG_WARN([Cannot compile AVX512 intrinsics for Xeon nor Xeon Phi. Defaulting to Xeon.])
+        can_compile_avx512_xeon=yes
       fi
     fi
   fi
