+@WITH_COMPLEX_AVX512_BLOCK1_KERNEL_TRUE@src/elpa2/kernels/complex_avx512_1hv_double_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
+@WANT_SINGLE_PRECISION_COMPLEX_TRUE@@WITH_COMPLEX_AVX512_BLOCK1_KERNEL_TRUE@src/elpa2/kernels/complex_avx512_1hv_single_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
 @WITH_COMPLEX_SVE128_BLOCK1_KERNEL_TRUE@am__objects_93 = src/elpa2/kernels/complex_sve128_1hv_double_precision.lo
 @WANT_SINGLE_PRECISION_COMPLEX_TRUE@@WITH_COMPLEX_SVE128_BLOCK1_KERNEL_TRUE@am__objects_94 = src/elpa2/kernels/complex_sve128_1hv_single_precision.lo
 @WITH_COMPLEX_SVE256_BLOCK1_KERNEL_TRUE@am__objects_95 = src/elpa2/kernels/complex_sve256_1hv_double_precision.lo
@@ -20544,6 +20552,8 @@
 @WANT_SINGLE_PRECISION_COMPLEX_TRUE@@WITH_COMPLEX_AVX2_BLOCK2_KERNEL_TRUE@am__objects_106 = src/elpa2/kernels/complex_avx2_2hv_single_precision.lo
 @WITH_COMPLEX_AVX512_BLOCK2_KERNEL_TRUE@am__objects_107 = src/elpa2/kernels/complex_avx512_2hv_double_precision.lo
 @WANT_SINGLE_PRECISION_COMPLEX_TRUE@@WITH_COMPLEX_AVX512_BLOCK2_KERNEL_TRUE@am__objects_108 = src/elpa2/kernels/complex_avx512_2hv_single_precision.lo
+@WITH_COMPLEX_AVX512_BLOCK2_KERNEL_TRUE@src/elpa2/kernels/complex_avx512_2hv_double_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
+@WANT_SINGLE_PRECISION_COMPLEX_TRUE@@WITH_COMPLEX_AVX512_BLOCK2_KERNEL_TRUE@src/elpa2/kernels/complex_avx512_2hv_single_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
