 @WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_AVX512_BLOCK6_KERNEL_TRUE@am__objects_76 = src/elpa2/kernels/real_avx512_6hv_single_precision.lo
+@WITH_REAL_AVX512_BLOCK6_KERNEL_TRUE@src/elpa2/kernels/real_avx512_6hv_double_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
+@WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_AVX512_BLOCK6_KERNEL_TRUE@src/elpa2/kernels/real_avx512_6hv_single_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
 @WITH_REAL_SVE128_BLOCK6_KERNEL_TRUE@am__objects_77 = src/elpa2/kernels/real_sve128_6hv_double_precision.lo
 @WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_SVE128_BLOCK6_KERNEL_TRUE@am__objects_78 = src/elpa2/kernels/real_sve128_6hv_single_precision.lo
