From: ELPA force_all_x86_kernel Makefile.in patch
Subject: [PATCH] Add per-object AVX512 CFLAGS to pre-generated Makefile.in

When autoreconf does not regenerate Makefile.in from Makefile.am, the
per-object CFLAGS for AVX512 kernel .lo files are missing. This patch
adds them directly to Makefile.in, inserting AM_CFLAGS += $(AVX512_CFLAGS)
rules after each AVX512 kernel object declaration.

Used alongside force_all_x86_kernel.patch and force_avx512_configure.patch.

--- a/Makefile.in
+++ b/Makefile.in
@@ -20474,6 +20474,8 @@
 @WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_AVX2_BLOCK2_KERNEL_TRUE@am__objects_36 = src/elpa2/kernels/real_avx2_2hv_single_precision.lo
 @WITH_REAL_AVX512_BLOCK2_KERNEL_TRUE@am__objects_37 = src/elpa2/kernels/real_avx512_2hv_double_precision.lo
 @WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_AVX512_BLOCK2_KERNEL_TRUE@am__objects_38 = src/elpa2/kernels/real_avx512_2hv_single_precision.lo
+@WITH_REAL_AVX512_BLOCK2_KERNEL_TRUE@src/elpa2/kernels/real_avx512_2hv_double_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
+@WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_AVX512_BLOCK2_KERNEL_TRUE@src/elpa2/kernels/real_avx512_2hv_single_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
 @WITH_REAL_SVE128_BLOCK2_KERNEL_TRUE@am__objects_39 = src/elpa2/kernels/real_sve128_2hv_double_precision.lo
 @WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_SVE128_BLOCK2_KERNEL_TRUE@am__objects_40 = src/elpa2/kernels/real_sve128_2hv_single_precision.lo
 @WITH_REAL_SVE256_BLOCK2_KERNEL_TRUE@am__objects_41 = src/elpa2/kernels/real_sve256_2hv_double_precision.lo
@@ -20493,6 +20495,8 @@
 @WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_AVX2_BLOCK4_KERNEL_TRUE@am__objects_55 = src/elpa2/kernels/real_avx2_4hv_single_precision.lo
 @WITH_REAL_AVX512_BLOCK4_KERNEL_TRUE@am__objects_56 = src/elpa2/kernels/real_avx512_4hv_double_precision.lo
 @WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_AVX512_BLOCK4_KERNEL_TRUE@am__objects_57 = src/elpa2/kernels/real_avx512_4hv_single_precision.lo
+@WITH_REAL_AVX512_BLOCK4_KERNEL_TRUE@src/elpa2/kernels/real_avx512_4hv_double_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
+@WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_AVX512_BLOCK4_KERNEL_TRUE@src/elpa2/kernels/real_avx512_4hv_single_precision.lo: AM_CFLAGS += $(AVX512_CFLAGS)
 @WITH_REAL_SVE128_BLOCK4_KERNEL_TRUE@am__objects_58 = src/elpa2/kernels/real_sve128_4hv_double_precision.lo
 @WANT_SINGLE_PRECISION_REAL_TRUE@@WITH_REAL_SVE128_BLOCK4_KERNEL_TRUE@am__objects_59 = src/elpa2/kernels/real_sve128_4hv_single_precision.lo
 @WITH_REAL_SVE256_BLOCK4_KERNEL_TRUE@am__objects_60 = src/elpa2/kernels/real_sve256_4hv_double_precision.lo
@@ -20512,6 +20516,8 @@
