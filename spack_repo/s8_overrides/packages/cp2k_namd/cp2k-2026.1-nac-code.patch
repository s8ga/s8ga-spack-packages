    END SUBROUTINE compute_phase_eigenvectors
 
+! **************************************************************************************************
+!> \brief Transform TDDFPT Ritz vectors from AO basis to the occ/virt MO basis and stash
+!>        them (with eigenvalues) into the qs_nac_methods module-level SAVE state for the
+!>        on-the-fly TDDFPT-NAC coupling. Ownership of evects/evals_local is transferred
+!>        (stolen) by nac_set_tddfpt_data.
+!> \param sub_env ...
+!> \param gs_mos ...
+!> \param S_evects ...
+!> \param evals ...
+! **************************************************************************************************
+   SUBROUTINE tddfpt_save_evects(sub_env, gs_mos, S_evects, evals)
+
+      TYPE(tddfpt_subgroup_env_type)                     :: sub_env
+      TYPE(tddfpt_ground_state_mos), DIMENSION(:)        :: gs_mos
+      TYPE(cp_fm_type), DIMENSION(:, :)                  :: S_evects
+      REAL(kind=dp), DIMENSION(:)                        :: evals
+
+      CHARACTER(LEN=*), PARAMETER                        :: routineN = 'tddfpt_save_evects'
+
+      INTEGER                                            :: handle, ispin, istate, nao, nspins, &
+                                                            nstates
+      TYPE(cp_fm_struct_type), POINTER                   :: fmstruct
+      TYPE(cp_fm_type), DIMENSION(:, :), POINTER         :: evects
+      REAL(kind=dp), DIMENSION(:), POINTER               :: evals_local
+
+      CALL timeset(routineN, handle)
+
+      nspins = SIZE(S_evects, 1)
+      nstates = SIZE(S_evects, 2)
+      CALL cp_fm_get_info(gs_mos(1)%mos_occ, nrow_global=nao)
+
+      ALLOCATE (evects(nspins, nstates))
+      ALLOCATE (evals_local(nstates))
+
+      DO istate = 1, nstates
+         DO ispin = 1, nspins
+            NULLIFY (fmstruct)
+            CALL cp_fm_struct_create(fmstruct, para_env=sub_env%para_env, &
+                                     context=sub_env%blacs_env, &
+                                     nrow_global=SIZE(gs_mos(ispin)%evals_occ), &
+                                     ncol_global=SIZE(gs_mos(ispin)%evals_virt))
+            CALL cp_fm_create(evects(ispin, istate), fmstruct)
+            CALL cp_fm_struct_release(fmstruct)
+         END DO
+      END DO
+
+      DO istate = 1, nstates
+         DO ispin = 1, nspins
+            CALL parallel_gemm("T", "N", &
+                               SIZE(gs_mos(ispin)%evals_occ), &
+                               SIZE(gs_mos(ispin)%evals_virt), &
+                               nao, &
+                               1.0_dp, &
+                               S_evects(ispin, istate), &
+                               gs_mos(ispin)%mos_virt, &
+                               0.0_dp, &
+                               evects(ispin, istate))
+         END DO
+      END DO
+      evals_local(:) = evals
+
+      ! Hand ownership to qs_nac_methods (caller pointers are NULLIFY'd inside the setter)
+      CALL nac_set_tddfpt_data(evects, evals_local)
+
+      CALL timestop(handle)
+   END SUBROUTINE tddfpt_save_evects
+
 END MODULE qs_tddfpt2_restart
