+! **************************************************************************************************
+!> \brief Ownership-stealing setter: receive TDDFPT Ritz vectors + eigenvalues (stashed by
+!>        qs_tddfpt2_restart.tddfpt_save_evects) into module SAVE state. Releases prior state.
+! **************************************************************************************************
+   SUBROUTINE nac_set_tddfpt_data(evects, evals)
+      TYPE(cp_fm_type), DIMENSION(:, :), POINTER         :: evects
+      REAL(kind=dp), DIMENSION(:), POINTER               :: evals
+
+      CHARACTER(LEN=*), PARAMETER                        :: routineN = 'nac_set_tddfpt_data'
+
+      INTEGER                                            :: handle, ispin, istate
+
+      CALL timeset(routineN, handle)
+
+      IF (ASSOCIATED(tddfpt_evects_state)) THEN
+         DO istate = 1, SIZE(tddfpt_evects_state, 2)
+            DO ispin = 1, SIZE(tddfpt_evects_state, 1)
+               CALL cp_fm_release(tddfpt_evects_state(ispin, istate))
+            END DO
+         END DO
+         DEALLOCATE (tddfpt_evects_state)
+      END IF
+      IF (ASSOCIATED(tddfpt_evals_state)) DEALLOCATE (tddfpt_evals_state)
+
+      tddfpt_evects_state => evects
+      tddfpt_evals_state => evals
+      NULLIFY (evects, evals)
+
+      CALL timestop(handle)
+   END SUBROUTINE nac_set_tddfpt_data
+
+! **************************************************************************************************
+!> \brief Release all module SAVE state (MO sets, TDDFPT arrays, file handles, cached flags).
+!        Called from qs_energy_utils.F finalize + self-detect at the start of a new MD run.
+! **************************************************************************************************
+   SUBROUTINE nac_release()
+      CHARACTER(LEN=*), PARAMETER                        :: routineN = 'nac_release'
+
+      INTEGER                                            :: handle, i, irep, ispin, istate
+
+      CALL timeset(routineN, handle)
+
+      IF (ASSOCIATED(last_mo_reps)) THEN
+         DO irep = 1, nac_n_rep
+            ! Close files for this rep (load from _r arrays into scalar working vars)
+            nac_eigtxt_unit(:) = nac_eigtxt_unit_r(:, irep)
+            nac_natxt_unit(:) = nac_natxt_unit_r(:, irep)
+            nac_eigtxt_open(:) = nac_eigtxt_open_r(:, irep)
+            nac_natxt_open(:) = nac_natxt_open_r(:, irep)
+            DO i = 1, 2
+               IF (nac_eigtxt_open(i)) THEN
+                  CLOSE (nac_eigtxt_unit(i))
+                  nac_eigtxt_unit(i) = -1
+                  nac_eigtxt_open(i) = .FALSE.
+               END IF
+               IF (nac_natxt_open(i)) THEN
+                  CLOSE (nac_natxt_unit(i))
+                  nac_natxt_unit(i) = -1
+                  nac_natxt_open(i) = .FALSE.
+               END IF
+            END DO
+            nac_eigtxt_unit_r(:, irep) = nac_eigtxt_unit(:)
+            nac_natxt_unit_r(:, irep) = nac_natxt_unit(:)
+            nac_eigtxt_open_r(:, irep) = nac_eigtxt_open(:)
+            nac_natxt_open_r(:, irep) = nac_natxt_open(:)
+            ! Deallocate mo_sets for this rep
+            DO ispin = 1, SIZE(last_mo_reps, 1)
+               IF (ASSOCIATED(last_mo_reps(ispin, irep)%mo_coeff)) &
+                  CALL deallocate_mo_set(last_mo_reps(ispin, irep))
+               IF (ASSOCIATED(ref_mo_reps(ispin, irep)%mo_coeff)) &
+                  CALL deallocate_mo_set(ref_mo_reps(ispin, irep))
+            END DO
+         END DO
+         DEALLOCATE (last_mo_reps, ref_mo_reps)
+      END IF
+
+      ! Nullify pointer-remapped working pointers (columns were owned by last_mo_reps/ref_mo_reps)
+      last_mo_state => NULL()
+      ref_mo_state => NULL()
+
+      IF (ASSOCIATED(tddfpt_evects_state)) THEN
+         DO istate = 1, SIZE(tddfpt_evects_state, 2)
+            DO ispin = 1, SIZE(tddfpt_evects_state, 1)
+               CALL cp_fm_release(tddfpt_evects_state(ispin, istate))
+            END DO
+         END DO
+         DEALLOCATE (tddfpt_evects_state)
+      END IF
+
+      IF (ASSOCIATED(tddfpt_evals_state)) DEALLOCATE (tddfpt_evals_state)
+
+      ! Deallocate per-rep storage arrays
+      IF (ALLOCATED(nac_use_bmin_bmax_r)) DEALLOCATE (nac_use_bmin_bmax_r)
+      IF (ALLOCATED(nac_reorder_orbitals_r)) DEALLOCATE (nac_reorder_orbitals_r)
+      IF (ALLOCATED(nac_occ_active_space_r)) DEALLOCATE (nac_occ_active_space_r)
+      IF (ALLOCATED(nac_vir_active_space_r)) DEALLOCATE (nac_vir_active_space_r)
+      IF (ALLOCATED(nac_bmin_r)) DEALLOCATE (nac_bmin_r)
+      IF (ALLOCATED(nac_bmax_r)) DEALLOCATE (nac_bmax_r)
+      IF (ALLOCATED(nac_phase_ref_interval_r)) DEALLOCATE (nac_phase_ref_interval_r)
+      IF (ALLOCATED(nac_filename_r)) DEALLOCATE (nac_filename_r)
+      IF (ALLOCATED(nac_eigtxt_unit_r)) DEALLOCATE (nac_eigtxt_unit_r)
+      IF (ALLOCATED(nac_natxt_unit_r)) DEALLOCATE (nac_natxt_unit_r)
+      IF (ALLOCATED(nac_eigtxt_open_r)) DEALLOCATE (nac_eigtxt_open_r)
+      IF (ALLOCATED(nac_natxt_open_r)) DEALLOCATE (nac_natxt_open_r)
+
+      nac_enabled = .FALSE.
+      nac_do_eigen = .FALSE.
+      nac_with_tddfpt = .FALSE.
+      nac_initialized = .FALSE.
+      nac_parsed = .FALSE.
+      nac_use_bmin_bmax = .FALSE.
+      nac_occ_active_space = 0
+      nac_vir_active_space = 0
+      nac_bmin = 0
+      nac_bmax = 0
+      nac_phase_ref_interval = 10
+      nac_reorder_orbitals = .FALSE.
+      nac_dt = 0.0_dp
+      nac_n_rep = 0
+      nac_irep = 1
+      nac_filename = "NAC"
+
+      CALL timestop(handle)
+   END SUBROUTINE nac_release
+
+! **************************************************************************************************
+!> \brief Private helper: element-wise real power of a full matrix (a_ij -> a_ij**n).
+!        Only used by nac_tddfpt_compute_s. Inlined here to avoid touching cp_fm_basic_linalg.
+! **************************************************************************************************
+   SUBROUTINE cp_fm_pow(matrix, n)
+      TYPE(cp_fm_type), INTENT(IN)                       :: matrix
+      REAL(kind=dp), INTENT(IN)                          :: n
+
+      CHARACTER(len=*), PARAMETER                        :: routineN = 'cp_fm_pow'
+
+      INTEGER                                            :: handle, icol_local, irow_local, mypcol, &
+                                                            myprow, ncol_local, nrow_local
+      REAL(kind=dp), DIMENSION(:, :), POINTER            :: a
+      TYPE(cp_blacs_env_type), POINTER                   :: context
+
+      CALL timeset(routineN, handle)
+
+      context => matrix%matrix_struct%context
+      myprow = context%mepos(1)
+      mypcol = context%mepos(2)
+
+      a => matrix%local_data
+
+      nrow_local = matrix%matrix_struct%nrow_locals(myprow)
+      ncol_local = matrix%matrix_struct%ncol_locals(mypcol)
+
+      DO icol_local = 1, ncol_local
+         DO irow_local = 1, nrow_local
+            a(irow_local, icol_local) = a(irow_local, icol_local)**n
+         END DO
+      END DO
+
+      CALL timestop(handle)
+   END SUBROUTINE cp_fm_pow
+
+! **************************************************************************************************
+!> \brief Hungarian / Kuhn-Munkres assignment solver, maximizing total benefit.
+!>        Faithful Fortran port of CA-NAC/mod_hungarian.py (maximize -> minimize of negated+shifted).
+!>        Runs on a small gathered n_active x n_active matrix on every rank (deterministic, no MPI).
+!>        For n <= ~50 the O(n^3) cost is sub-millisecond, so no OpenMP/MPI is applied here on
+!>        purpose (overhead would exceed work). The heavy overlap/eigensolve stays distributed.
+!> \param benefit ... (n,n) benefit matrix, e.g. |overlap|^2
+!> \param perm ...    (n) OUT: perm(i) = column index matched to row i
+! **************************************************************************************************
+   SUBROUTINE nac_kuhn_munkres(benefit, perm)
+      REAL(kind=dp), DIMENSION(:, :), INTENT(IN)  :: benefit
+      INTEGER, DIMENSION(:),          INTENT(OUT) :: perm
+
+      CHARACTER(LEN=*), PARAMETER :: routineN = 'nac_kuhn_munkres'
+
+      INTEGER                                            :: handle, i, j, n, step, &
+                                                            path_row_0, path_col_0, colcount
+      REAL(kind=dp), ALLOCATABLE, DIMENSION(:, :)        :: X
+      INTEGER, ALLOCATABLE, DIMENSION(:, :)              :: M
+      INTEGER, ALLOCATABLE, DIMENSION(:)                 :: Rcov, Ccov
+
+      CALL timeset(routineN, handle)
+
+      n = SIZE(benefit, 1)
+      CPASSERT(SIZE(benefit, 2) == n)
+      CPASSERT(SIZE(perm) == n)
+      ALLOCATE (X(n, n), M(n, n), Rcov(n), Ccov(n))
+
+      ! maximize -> minimize: X = -(benefit) + maxval + eps  (mod_hungarian.maximize, lines 442-445)
+      X = -benefit + MAXVAL(benefit) + 1.0E-5_dp
+      M = 0; Rcov = 0; Ccov = 0
+      perm = 0
+
+      ! driver loop (step1->2->3->4<->5<->6->7). path_row_0/path_col_0 are host-associated
+      ! into km_step5, so they must live in this scope (not a nested BLOCK).
+      step = 1
+      path_row_0 = -1; path_col_0 = -1
+      DO WHILE (step /= 7)
+         SELECT CASE (step)
+         CASE (1); step = km_step1()
+         CASE (2); step = km_step2()
+         CASE (3); CALL km_step3(step, colcount)
+         CASE (4); CALL km_step4(step, path_row_0, path_col_0)
+         CASE (5); CALL km_step5(step)
+         CASE (6); step = km_step6()
+         END SELECT
+      END DO
+
+      ! compute_assignment: perm(i) = j where M(i,j)==1 (exactly one starred zero per row)
+      DO i = 1, n
+         perm(i) = 0
+         DO j = 1, n
+            IF (M(i, j) == 1) THEN
+               perm(i) = j
+               EXIT
+            END IF
+         END DO
+      END DO
+
+      DEALLOCATE (X, M, Rcov, Ccov)
+      CALL timestop(handle)
+
+   CONTAINS
+
+      ! ---- step1: subtract row minima from each row (mod_hungarian.step1) ----
+      INTEGER FUNCTION km_step1()
+         INTEGER :: r
+         DO r = 1, n
+            X(r, :) = X(r, :) - MINVAL(X(r, :))
+         END DO
+         km_step1 = 2
+      END FUNCTION km_step1
+
+      ! ---- step2: star uncovered zeros, then uncover all (mod_hungarian.step2) ----
+      INTEGER FUNCTION km_step2()
+         INTEGER :: i, j
+         DO i = 1, n
+            DO j = 1, n
+               IF (ABS(X(i, j)) < 1.0E-10_dp .AND. Rcov(i) == 0 .AND. Ccov(j) == 0) THEN
+                  M(i, j) = 1
+                  Rcov(i) = 1; Ccov(j) = 1
+               END IF
+            END DO
+         END DO
+         Rcov = 0; Ccov = 0
+         km_step2 = 3
+      END FUNCTION km_step2
+
+      ! ---- step3: cover columns with a star; done if all covered (mod_hungarian.step3) ----
+      SUBROUTINE km_step3(step, colcount)
+         INTEGER, INTENT(OUT) :: step, colcount
+         INTEGER :: i, j
+         Ccov = 0
+         DO i = 1, n
+            DO j = 1, n
+               IF (M(i, j) == 1) Ccov(j) = 1
+            END DO
+         END DO
+         colcount = SUM(Ccov)
+         step = 4
+         IF (colcount >= n) step = 7
+      END SUBROUTINE km_step3
+
+      ! ---- helpers: find_a_zero, find_star_in_row/col, find_prime_in_row ----
+      SUBROUTINE km_find_a_zero(r, c)
+         INTEGER, INTENT(OUT) :: r, c
+         INTEGER :: i, j
+         r = -1; c = -1
+         outer: DO i = 1, n
+            DO j = 1, n
+               IF (ABS(X(i, j)) < 1.0E-20_dp .AND. Rcov(i) == 0 .AND. Ccov(j) == 0) THEN
+                  r = i; c = j; EXIT outer
+               END IF
+            END DO
+         END DO outer
+      END SUBROUTINE km_find_a_zero
+
+      INTEGER FUNCTION km_star_in_row(row)
+         INTEGER, INTENT(IN) :: row
+         INTEGER :: j
+         km_star_in_row = -1
+         DO j = 1, n
+            IF (M(row, j) == 1) km_star_in_row = j
+         END DO
+      END FUNCTION km_star_in_row
+
+      INTEGER FUNCTION km_star_in_col(col)
+         INTEGER, INTENT(IN) :: col
+         INTEGER :: i
+         km_star_in_col = -1
+         DO i = 1, n
+            IF (M(i, col) == 1) km_star_in_col = i
+         END DO
+      END FUNCTION km_star_in_col
+
+      INTEGER FUNCTION km_prime_in_row(row)
+         INTEGER, INTENT(IN) :: row
+         INTEGER :: j
+         km_prime_in_row = -1
+         DO j = 1, n
+            IF (M(row, j) == 2) km_prime_in_row = j
+         END DO
+      END FUNCTION km_prime_in_row
+
+      ! ---- step4: prime uncovered zeros, augment-search (mod_hungarian.step4) ----
+      SUBROUTINE km_step4(step, pr0, pc0)
+         INTEGER, INTENT(OUT) :: step, pr0, pc0
+         INTEGER :: row, col, col_
+         LOGICAL :: done
+         step = 6; pr0 = -1; pc0 = -1
+         done = .FALSE.
+         DO WHILE (.NOT. done)
+            CALL km_find_a_zero(row, col)
+            IF (row == -1) THEN
+               done = .TRUE.; step = 6
+            ELSE
+               M(row, col) = 2
+               col_ = km_star_in_row(row)
+               IF (col_ > -1) THEN
+                  col = col_
+                  Rcov(row) = 1; Ccov(col) = 0
+               ELSE
+                  done = .TRUE.; pr0 = row; pc0 = col; step = 5
+               END IF
+            END IF
+         END DO
+      END SUBROUTINE km_step4
+
+      ! ---- step5: alternating primed/starred path, augment, clear (mod_hungarian.step5) ----
+      SUBROUTINE km_step5(step)
+         INTEGER, INTENT(OUT) :: step
+         INTEGER, ALLOCATABLE, DIMENSION(:, :) :: path
+         INTEGER :: pcnt, r, c
+         LOGICAL :: done
+         ALLOCATE (path(2*n, 2)); path = 0
+         pcnt = 1; path(1, 1) = path_row_0; path(1, 2) = path_col_0
+         done = .FALSE.
+         DO WHILE (.NOT. done)
+            r = km_star_in_col(path(pcnt, 2))
+            IF (r > -1) THEN
+               pcnt = pcnt + 1
+               path(pcnt, 1) = r; path(pcnt, 2) = path(pcnt - 1, 2)
+            ELSE
+               done = .TRUE.
+            END IF
+            IF (.NOT. done) THEN
+               c = km_prime_in_row(path(pcnt, 1))
+               pcnt = pcnt + 1
+               path(pcnt, 1) = path(pcnt - 1, 1); path(pcnt, 2) = c
+            END IF
+         END DO
+         ! augment_path: flip stars along path (1->0, else->1)
+         DO r = 1, pcnt
+            IF (M(path(r, 1), path(r, 2)) == 1) THEN
+               M(path(r, 1), path(r, 2)) = 0
+            ELSE
+               M(path(r, 1), path(r, 2)) = 1
+            END IF
+         END DO
+         Rcov = 0; Ccov = 0          ! clear_covers
+         WHERE (M == 2) M = 0        ! erase_primes
+         step = 3
+         DEALLOCATE (path)
+      END SUBROUTINE km_step5
+
+      ! ---- step6: reduced-cost update (mod_hungarian.step6) ----
+      INTEGER FUNCTION km_step6()
+         INTEGER :: i, j
+         REAL(kind=dp) :: minval
+         minval = HUGE(minval)
+         DO i = 1, n
+            DO j = 1, n
+               IF (Rcov(i) == 0 .AND. Ccov(j) == 0) THEN
+                  IF (minval > X(i, j)) minval = X(i, j)
+               END IF
+            END DO
+         END DO
+         DO i = 1, n
+            DO j = 1, n
+               IF (Rcov(i) == 1) X(i, j) = X(i, j) + minval
+               IF (Ccov(j) == 0) X(i, j) = X(i, j) - minval
+            END DO
+         END DO
+         km_step6 = 4
+      END FUNCTION km_step6
+
+   END SUBROUTINE nac_kuhn_munkres
+
+! **************************************************************************************************
+!> \brief Hungarian orbital matching + step-to-step phase on the active-space overlap.
+!>        Mirrors CA-NAC/CAnac.py:302-309 + phase_from_tdolap. Gathers the small n_active x
+!>        n_active overlap (replicated on all ranks), runs Kuhn-Munkres on |O_ij|^2, reorders
+!>        O_ij columns and O_ji rows by the matched permutation (orbital i keeps identity
+!>        across steps), then flips signs so diag(O_ij) > 0. Writes back in place; the caller's
+!>        overlap_diff and dt-scaled coupling then run on the reordered/phased matrices.
+!>        No MPI comm: every rank gathers the same matrix and computes the same deterministic
+!>        permutation; cp_fm_set_submatrix updates each rank's local block from replicated input.
+! **************************************************************************************************
+   SUBROUTINE nac_hungarian_reorder_phase(oij_fm, oji_fm)
+      TYPE(cp_fm_type), INTENT(INOUT)                      :: oij_fm, oji_fm
+
+      CHARACTER(LEN=*), PARAMETER :: routineN = 'nac_hungarian_reorder_phase'
+
+      INTEGER                                            :: handle, i, j, n
+      INTEGER, ALLOCATABLE, DIMENSION(:)                   :: perm
+      REAL(kind=dp), ALLOCATABLE, DIMENSION(:)             :: fsign
+      REAL(kind=dp), ALLOCATABLE, DIMENSION(:, :)          :: benefit, oij, oij_new, oji, oji_new
+
+      CALL timeset(routineN, handle)
+
+      CALL cp_fm_get_info(oij_fm, nrow_global=n, ncol_global=n)
+      ALLOCATE (oij(n, n), oji(n, n), benefit(n, n), oij_new(n, n), oji_new(n, n), perm(n), fsign(n))
+
+      CALL cp_fm_get_submatrix(oij_fm, oij, 1, 1, n, n)   ! O_ij = <psi_i(t)|psi_j(t+dt)>
+      CALL cp_fm_get_submatrix(oji_fm, oji, 1, 1, n, n)   ! O_ji = <psi_i(t+dt)|psi_j(t)>
+
+      ! Hungarian on |O_ij|^2 -> perm(i) = t+dt column matched to t row i
+      benefit = oij**2
+      CALL nac_kuhn_munkres(benefit, perm)
+
+      ! Reorder so orbital index i tracks identity across steps:
+      !   oij_new(:, j) = oij(:, perm(j))   (align t+dt / column index)
+      !   oji_new(i, :) = oji(perm(i), :)   (align t+dt / row index)
+      DO j = 1, n
+         oij_new(:, j) = oij(:, perm(j))
+      END DO
+      DO i = 1, n
+         oji_new(i, :) = oji(perm(i), :)
+      END DO
+
+      ! Step-to-step phase (phase_from_tdolap): f_i = sign(diag(oij_new)); force diag > 0
+      DO i = 1, n
+         fsign(i) = SIGN(1.0_dp, oij_new(i, i))
+      END DO
+      DO j = 1, n
+         oij_new(:, j) = oij_new(:, j)*fsign(j)   ! t+dt is column index of oij
+      END DO
+      DO i = 1, n
+         oji_new(i, :) = oji_new(i, :)*fsign(i)   ! t+dt is row index of oji
+      END DO
+
+      ! Write back (alpha=1, beta=0 default -> replace the full block)
+      CALL cp_fm_set_submatrix(oij_fm, oij_new, 1, 1, n, n)
+      CALL cp_fm_set_submatrix(oji_fm, oji_new, 1, 1, n, n)
+
+      DEALLOCATE (oij, oji, benefit, oij_new, oji_new, perm, fsign)
+      CALL timestop(handle)
+   END SUBROUTINE nac_hungarian_reorder_phase
+
+END MODULE qs_nac_methods
