+! **************************************************************************************************
+!> \brief Creates the input section for On-the-fly Non-Adiabatic Coupling (Hefei-NAMD output).
+!> \param section ...
+! **************************************************************************************************
+   SUBROUTINE create_nac_section(section)
+      TYPE(section_type), POINTER                        :: section
+
+      TYPE(keyword_type), POINTER                        :: keyword
+      TYPE(section_type), POINTER                        :: print_key
+
+      CPASSERT(.NOT. ASSOCIATED(section))
+      CALL section_create(section, __LOCATION__, name="NAC", &
+                          description="Parameters needed to set Non-Adiabatic Coupling calculation "// &
+                          "(on-the-fly instantaneous-overlap framework). Produces Hefei-NAMD native "// &
+                          "EIGTXT (band energies, eV) and NATXT (raw antisymmetric overlap difference) files.", &
+                          n_keywords=7, n_subsections=1, repeats=.TRUE.)
+
+      NULLIFY (keyword)
+
+      CALL keyword_create(keyword, __LOCATION__, &
+                          name="_SECTION_PARAMETERS_", &
+                          description="Controls the activation of the NAC procedure", &
+                          default_l_val=.FALSE., &
+                          lone_keyword_l_val=.TRUE.)
+      CALL section_add_keyword(section, keyword)
+      CALL keyword_release(keyword)
+
+      CALL keyword_create(keyword, __LOCATION__, name="ACTIVE_SPACE_OCC", &
+                          description="Number of occupied orbitals in the active space (mode A). "// &
+                          "Mutually exclusive with ACTIVE_SPACE_BMIN/BMAX.", &
+                          usage="ACTIVE_SPACE_OCC 10", &
+                          n_var=1, type_of_var=integer_t, default_i_val=0)
+      CALL section_add_keyword(section, keyword)
+      CALL keyword_release(keyword)
+
+      CALL keyword_create(keyword, __LOCATION__, name="ACTIVE_SPACE_VIR", &
+                          description="Number of virtual orbitals in the active space (mode A). "// &
+                          "Mutually exclusive with ACTIVE_SPACE_BMIN/BMAX.", &
+                          usage="ACTIVE_SPACE_VIR 10", &
+                          n_var=1, type_of_var=integer_t, default_i_val=0)
+      CALL section_add_keyword(section, keyword)
+      CALL keyword_release(keyword)
+
+      CALL keyword_create(keyword, __LOCATION__, name="ACTIVE_SPACE_BMIN", &
+                          description="Lowest band index of the active space (1-based, mode B). "// &
+                          "Must be used together with ACTIVE_SPACE_BMAX.", &
+                          usage="ACTIVE_SPACE_BMIN 11", &
+                          n_var=1, type_of_var=integer_t, default_i_val=0)
+      CALL section_add_keyword(section, keyword)
+      CALL keyword_release(keyword)
+
+      CALL keyword_create(keyword, __LOCATION__, name="ACTIVE_SPACE_BMAX", &
+                          description="Highest band index of the active space (1-based, mode B). "// &
+                          "Must be used together with ACTIVE_SPACE_BMIN.", &
+                          usage="ACTIVE_SPACE_BMAX 30", &
+                          n_var=1, type_of_var=integer_t, default_i_val=0)
+      CALL section_add_keyword(section, keyword)
+      CALL keyword_release(keyword)
+
+      CALL keyword_create(keyword, __LOCATION__, name="PHASE_REF_INTERVAL", &
+                          description="Refresh the phase-correction reference MO set every N MD steps "// &
+                          "(prevents long-term accumulation of sign errors).", &
+                          usage="PHASE_REF_INTERVAL 10", &
+                          n_var=1, type_of_var=integer_t, default_i_val=10)
+      CALL section_add_keyword(section, keyword)
+      CALL keyword_release(keyword)
+
+      CALL keyword_create(keyword, __LOCATION__, name="REORDER_ORBITALS", &
+                          description="Enable Hungarian (Kuhn-Munkres) orbital matching across MD steps "// &
+                          "to track orbital identity through avoided crossings. When TRUE, switches to "// &
+                          "step-to-step sign(diag(overlap)) phase (CA-NAC/Hefei-NAMD convention, no saved "// &
+                          "reference). Default FALSE = Tsai sign-diagonal against saved ref_mo.", &
+                          usage="REORDER_ORBITALS .TRUE.", &
+                          n_var=0, type_of_var=logical_t, default_l_val=.FALSE., lone_keyword_l_val=.TRUE.)
+      CALL section_add_keyword(section, keyword)
+      CALL keyword_release(keyword)
+
+      CALL keyword_create(keyword, __LOCATION__, name="NAC_FILENAME", &
+                          description="Base filename for Hefei-NAMD output. Generates <NAME>.EIGTXT and "// &
+                          "<NAME>.NATXT (plus _s2 variants for spin-unrestricted calculations).", &
+                          usage="NAC_FILENAME CP2K_NAC", &
+                          n_var=1, type_of_var=lchar_t, default_lc_val="NAC")
+      CALL section_add_keyword(section, keyword)
+      CALL keyword_release(keyword)
+
+      NULLIFY (print_key)
+      CALL cp_print_key_section_create(print_key, __LOCATION__, name="PRINT", &
+                                       description="Controls the optional human-readable NAC dump (debug). "// &
+                                       "Hefei-NAMD EIGTXT/NATXT files are always written when NAC is enabled.", &
+                                       print_level=medium_print_level, filename="NAC", unit_str="hartree")
+      CALL section_add_subsection(section, print_key)
+      CALL section_release(print_key)
+
+   END SUBROUTINE create_nac_section
+
 END MODULE input_cp2k_properties_dft
